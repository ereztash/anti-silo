{
  "output_dir": "anti_silo_out",
  "claim_globs": ["**/*.md"],
  "ingest_extensions": [".md", ".txt", ".csv", ".json", ".html", ".htm", ".docx", ".xlsx", ".pdf"],
  "index_extensions": [".md", ".pdf", ".html", ".htm"],
  "text_index_extensions": [".md"],
  "exclude_dirs": [".git", ".obsidian", "anti_silo_out", "anti_silo_out_clean", "__pycache__", "node_modules", ".venv", "dist", "build", "vendor"],
  "eligible_tiers": ["triangulated"],
  "candidate_tiers": [],
  "raw_source_only": true,
  "contradiction_penalty": {
    "enabled": true,
    "hard_block_threshold": 6,
    "weights": {
      "graph_only_no_lineage": 1,
      "temporal_without_lineage": 1,
      "lineage_without_raw_source": 2,
      "corroborated_without_raw_source": 3,
      "outcome_without_raw_source": 4,
      "decision_without_raw_source": 5,
      "usage_without_raw_source": 5,
      "refuted_or_blocked": 8,
      "extraction_failed": 8,
      "extraction_truncated": 6
    }
  },
  "profiles": {
    "default": {},
    "research": {
      "include_dirs": ["research", "sources", "claims", "papers", "articles", "bibliography", "references", "external", "Deep research", "מאמרים", "חוסן", "שילוב"],
      "exclude_dirs": ["archive", "drafts", "tmp"]
    },
    "rag": {
      "include_dirs": ["sources", "source", "knowledge", "docs", "documents", "claims", "research"],
      "exclude_dirs": ["prompts", "scratch", "drafts", "archive"]
    },
    "repo": {
      "exclude_dirs": [".git", ".obsidian", "anti_silo_out", "anti_silo_out_clean", "__pycache__", "node_modules", ".venv", "dist", "build", "vendor", ".pytest_cache", ".mypy_cache"]
    },
    "cor-sys": {
      "candidate_tiers": ["source_backed"],
      "corroboration_markers": [
        "corroborated",
        "field_validated",
        "methodological_review",
        "adversarial_review",
        "קורוברציה",
        "פנקס-קורוברציה",
        "שורת פנקס",
        "שורת-פנקס",
        "שרד →",
        "שרד -",
        "שרד —",
        "דויק",
        "מקורבר-פנקס",
        "מקורבר-מפעיל",
        "מאומתת-אובייקטיבית",
        "אימות-שטח"
      ],
      "promotion_policy": {
        "blocked_tiers": ["graph_only", "indexed_unverified", "corroborated_no_source", "ledger_supported", "refuted_or_blocked"],
        "review_tiers": ["source_backed"]
      }
    },
    "prompts": {
      "include_dirs": ["prompts", "סוכנים", "agents", "templates", "playbooks"],
      "exclude_dirs": ["node_modules", ".git", "archive"]
    }
  },
  "claim_markers": ["claim:", "status:", "maturity:", "hypothesis:", "assertion:"],
  "synthesis_markers": ["integrated model", "research gap", "evidence synthesis", "meta-analysis", "systematic literature review", "validated framework", "first comprehensive", "empirically validated", "research backbone", "bridging research evidence"],
  "source_spine_markers": ["source_hash:", "source_spine:", "bibliography", "references", "paper_list", "paper list", "slr artifact", "source-of-truth"],
  "blocked_markers": ["blocked", "refuted", "do not promote", "over_claimed"],
  "blocked_marker_mode": "field",
  "blocked_marker_fields": ["status", "tier", "decision", "maturity", "promotion", "gate", "blocked", "refuted"],
  "blocked_line_prefixes": ["blocked:", "refuted:", "do not promote", "over_claimed"],
  "corroboration_markers": ["corroborated", "field_validated", "methodological_review", "adversarial_review"],
  "ledger_markers": ["ledger", "corroboration ledger", "פנקס"],
  "promotion_policy": {
    "blocked_tiers": ["graph_only", "source_backed", "indexed_unverified", "corroborated_no_source", "ledger_supported", "refuted_or_blocked"],
    "review_tiers": []
  },
  "surfaces": {
    "source_truth_marker": {
      "authority": "source_of_truth",
      "can_anchor_claim": true,
      "raw_source": true,
      "path_contains": ["source", "sources"],
      "text_contains": ["source_of_truth: true", "ground-truth", "source truth"]
    },
    "research_library_source": {
      "authority": "research_library_source",
      "can_anchor_claim": true,
      "raw_source": true,
      "path_contains": ["paper", "papers", "article", "articles", "מאמר"],
      "extensions": [".pdf", ".html", ".htm"],
      "text_contains": []
    },
    "crm_field_anchor": {
      "authority": "field_anchor",
      "can_anchor_claim": true,
      "raw_source": true,
      "path_contains": ["crm", "client", "customer"],
      "text_contains": ["crm", "customer_id", "field_anchor"]
    },
    "outcome_truth": {
      "authority": "field_outcome",
      "can_anchor_claim": true,
      "raw_source": true,
      "path_contains": ["outcome", "outcomes"],
      "text_contains": ["value_realized", "paid_engagement", "conversion_event", "decision_changed"]
    },
    "prereg_truth": {
      "authority": "prospective_test_design",
      "can_anchor_claim": true,
      "raw_source": true,
      "path_contains": ["prereg", "pre-registration"],
      "text_contains": ["pre_registered", "prereg", "success_metric"]
    },
    "ledger_truth": {
      "authority": "source_of_truth",
      "can_anchor_claim": true,
      "raw_source": false,
      "path_contains": ["ledger", "corroboration"],
      "text_contains": ["corroboration ledger", "פנקס"]
    },
    "external_adjacent": {
      "authority": "external_candidate_only",
      "can_anchor_claim": false,
      "path_contains": ["external", "research"],
      "text_contains": ["external_source", "outside reference"]
    },
    "governance_contract": {
      "authority": "enforcement_truth",
      "can_anchor_claim": true,
      "raw_source": false,
      "path_contains": ["contract", "contracts"],
      "text_contains": ["authority_boundary", "contract:"]
    }
  }
}
