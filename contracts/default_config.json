{
  "output_dir": "anti_silo_out",
  "claim_globs": ["**/*.md"],
  "exclude_dirs": [".git", ".obsidian", "anti_silo_out", "anti_silo_out_clean", "__pycache__", "node_modules", ".venv", "dist", "build", "vendor"],
  "claim_markers": ["claim:", "status:", "maturity:", "hypothesis:", "assertion:"],
  "synthesis_markers": ["integrated model", "research gap", "evidence synthesis", "meta-analysis", "systematic literature review", "validated framework", "first comprehensive", "empirically validated", "research backbone", "bridging research evidence"],
  "source_spine_markers": ["source_hash:", "source_spine:", "bibliography", "references", "paper_list", "paper list", "slr artifact", "source-of-truth"],
  "blocked_markers": ["blocked", "refuted", "do not promote", "over_claimed"],
  "corroboration_markers": ["corroborated", "field_validated", "methodological_review", "adversarial_review"],
  "ledger_markers": ["ledger", "corroboration ledger", "פנקס"],
  "promotion_policy": {
    "blocked_tiers": ["graph_only", "source_backed", "corroborated_no_source", "ledger_supported", "refuted_or_blocked"]
  },
  "surfaces": {
    "source_truth_marker": {
      "authority": "source_of_truth",
      "can_anchor_claim": true,
      "path_contains": ["source", "sources"],
      "text_contains": ["source_of_truth: true", "ground-truth", "source truth"]
    },
    "crm_field_anchor": {
      "authority": "field_anchor",
      "can_anchor_claim": true,
      "path_contains": ["crm", "client", "customer"],
      "text_contains": ["crm", "customer_id", "field_anchor"]
    },
    "outcome_truth": {
      "authority": "field_outcome",
      "can_anchor_claim": true,
      "path_contains": ["outcome", "outcomes"],
      "text_contains": ["value_realized", "paid_engagement", "conversion_event", "decision_changed"]
    },
    "prereg_truth": {
      "authority": "prospective_test_design",
      "can_anchor_claim": true,
      "path_contains": ["prereg", "pre-registration"],
      "text_contains": ["pre_registered", "prereg", "success_metric"]
    },
    "ledger_truth": {
      "authority": "source_of_truth",
      "can_anchor_claim": true,
      "path_contains": ["ledger", "corroboration"],
      "text_contains": ["corroboration ledger", "פנקס"]
    },
    "external_adjacent": {
      "authority": "external_candidate_only",
      "can_anchor_claim": false,
      "path_contains": ["external", "research"],
      "text_contains": ["external_source", "outside reference"]
    },
    "governance_contract": {
      "authority": "enforcement_truth",
      "can_anchor_claim": true,
      "path_contains": ["contract", "contracts"],
      "text_contains": ["authority_boundary", "contract:"]
    }
  }
}
